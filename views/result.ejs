<!DOCTYPE html>
<html data-theme="light">
<head>
    <title>Flight Result</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="bg-glow"></div>
    <div class="container d-flex justify-content-center align-items-center min-vh-100">
        <div class="card shadow-lg p-4 app-card text-center" style="width: 100%; max-width: 600px;">
            <h2 class="fw-bold project-title mb-4">Flight Cost Result</h2>
            
            <div class="result-box mb-4">
                <h1 class="text-success fw-bold"><%= cost %> <%= currency %></h1>
                <p class="lead">Distance: <strong><%= distance %> km</strong></p>
            </div>

            <div id="map" style="height: 350px; border-radius: 15px; margin-bottom: 20px; border: 1px solid rgba(255,255,255,0.1);"></div>

            <a = href="/" class="btn btn-primary w-100 py-2 fw-bold">Search Another Route</a>
        </div>
    </div>

    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
    <script>
        // 1. Force the theme to match what was selected on the home page
        const savedTheme = localStorage.getItem("theme") || "light";
        document.documentElement.setAttribute("data-theme", savedTheme);

        // 2. Map Logic (Fixed double declarations)
        const fromCoords = [parseFloat('<%= fromLat %>'), parseFloat('<%= fromLng %>')];
        const toCoords = [parseFloat('<%= toLat %>'), parseFloat('<%= toLng %>')];

        const map = L.map('map').setView(fromCoords, 4);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '&copy; OpenStreetMap'
        }).addTo(map);

        const marker1 = L.marker(fromCoords).addTo(map).bindPopup("Departure");
        const marker2 = L.marker(toCoords).addTo(map).bindPopup("Destination");

        const route = L.polyline([fromCoords, toCoords], {
            color: '#3b82f6',
            weight: 5,
            opacity: 0.7,
            dashArray: '10, 10' 
        }).addTo(map);

        // 3. Fix map render issues
        setTimeout(() => {
            map.invalidateSize();
            map.fitBounds(route.getBounds(), { padding: [40, 40] });
        }, 300);
    </script>
</body>
</html>